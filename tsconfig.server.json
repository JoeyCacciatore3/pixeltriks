{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist-server",
    "rootDir": "src",
    "baseUrl": ".",
    "paths": {
      "@sim/*": ["src/sim/*"],
      "@shared/*": ["src/shared/*"]
    }
  },
  "include": ["src/server/**/*", "src/sim/**/*", "src/shared/**/*"]
}
