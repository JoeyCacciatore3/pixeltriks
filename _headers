# Cloudflare Pages custom headers — PREVIEW DEPLOYMENTS ONLY.
#
# Production (pixeltriks.com) is governed by zone-level HTTP Response Header
# Modification rules in the Cloudflare dashboard — those override everything.
# This file exists for branch preview URLs (*.pixeltriks.pages.dev) where
# zone rules don't apply, and as human-readable documentation of intent.
#
# CF Pages MERGES all matching rules — keep paths non-overlapping.

# Service worker — NEVER cache
/sw.js
  Cache-Control: no-cache, no-store, must-revalidate

# HTML app shell — always revalidate
/index.html
  Cache-Control: no-cache, must-revalidate
/
  Cache-Control: no-cache, must-revalidate

# PWA manifest — 1h
/manifest.webmanifest
  Cache-Control: public, max-age=3600, must-revalidate

# Images — 24h
/icon.svg
  Cache-Control: public, max-age=86400

# Vendor libs (three.js, fonts, models) — 7 days, immutable
/vendor/*
  Cache-Control: public, max-age=604800, immutable

# 3D model assets — 7 days, immutable
/assets/*
  Cache-Control: public, max-age=604800, immutable
